{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Rebuild amwall (clean + release, stderr → swaplog.txt)",
            "type": "shell",
            "command": "chcp 65001 >nul && cargo clean && cargo build --release && cargo run --release 1> \"${workspaceFolder}\\swaplog.txt\" 2>&1",
            "group": "build",
            "problemMatcher": "$rustc",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/C"]
                },
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Build amwall (release, stderr → swaplog.txt)",
            "type": "shell",
            "command": "chcp 65001 >nul && cargo build --release && cargo run --release 1> \"${workspaceFolder}\\swaplog.txt\" 2>&1",
            "group": "build",
            "problemMatcher": "$rustc",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/C"]
                },
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Build + run amwall ELEVATED (UAC, stderr → swaplog.txt)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                ".vscode/run-elevated.ps1"
            ],
            "group": "build",
            "problemMatcher": "$rustc",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "Builds in release, then launches amwall.exe via UAC. The elevated cmd.exe wrapper handles stderr redirection (Start-Process -Verb RunAs can't redirect stdio directly). Helper script: .vscode/run-elevated.ps1"
        },
        {
            // Idempotent: cargo install with --locked is a fast
            // no-op when cargo-wix is already at the locked
            // version, so chaining this in front of every MSI
            // build costs <1s on warm runs. The Get-Command
            // guard skips even that on subsequent presses.
            "label": "amwall: ensure cargo-wix",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-Command",
                "if (-not (Get-Command cargo-wix -ErrorAction SilentlyContinue)) { Write-Host 'Installing cargo-wix...'; cargo install cargo-wix --locked } else { Write-Host 'cargo-wix already installed' }"
            ],
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "amwall: cargo build --release (msvc target)",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build",
                "--release",
                "--target",
                "x86_64-pc-windows-msvc"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true,
                "echo": true
            },
            "problemMatcher": "$rustc",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            // Builds the same multilingual MSI as the GitHub release
            // workflow by calling scripts/build-msi.ps1 — the workflow
            // calls the same script, so local Ctrl+Shift+B output and
            // tag-driven release output stay byte-identical (modulo
            // the embedded amwall.exe build host).
            //
            // Output: target\wix\amwall-<version>-x86_64.msi (with
            // every wix/lang/*.wxl transform embedded as a substorage
            // keyed by LCID; Windows Installer auto-selects the
            // matching transform at install time).
            //
            // dependsOn first builds the release exe so the MSI has
            // something to ship. The script itself rejects loudly if
            // the exe is missing.
            //
            // Prerequisite the task can't auto-install: WiX Toolset
            // 3.x (candle.exe / light.exe / torch.exe). The script
            // detects its absence and prints choco install
            // instructions instead of failing with "command not
            // found".
            "label": "Build MSI installer",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "scripts/build-msi.ps1"
            ],
            "dependsOrder": "sequence",
            "dependsOn": [
                "amwall: cargo build --release (msvc target)"
            ],
            // No `isDefault: true` here — every build-group task is
            // a peer, so Ctrl+Shift+B always shows the picker
            // instead of auto-running one (and instead of nagging
            // "select an instance to terminate" when the previous
            // default was already running).
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "echo": true
            },
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            // Convenience side-task: opens target\wix in
            // Explorer with the freshest MSI selected. Not the
            // default; reach via Ctrl+Shift+P -> "Tasks: Run
            // Task" -> "Reveal MSI in Explorer".
            "label": "Reveal MSI in Explorer",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-Command",
                "$msi = Get-ChildItem -Path target/wix -Filter *.msi -ErrorAction SilentlyContinue | Select-Object -Last 1; if ($msi) { Start-Process explorer.exe -ArgumentList \"/select,$($msi.FullName)\" } else { Write-Error 'No MSI found under target/wix - run \"Build MSI installer\" first.' }"
            ],
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}
