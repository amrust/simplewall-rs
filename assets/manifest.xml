<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<assembly xmlns="urn:schemas-microsoft-com:asm.v1" manifestVersion="1.0">
  <!--
    amwall application manifest.

    Three jobs:

      1. Pull in ComCtl32 v6 (the assemblyIdentity/dependency block).
         Without this we get the Win9x-era unthemed common controls,
         the listview header looks wrong, and REBARBANDINFOW expects
         the pre-Vista compatibility size.

      2. Mark the binary as DPI-aware via the windowsSettings block.
         Belt-and-braces with the runtime SetProcessDpiAwarenessContext
         call in src/gui.rs — the manifest setting is what
         Windows reads before our process starts, the runtime call
         covers the per-monitor v2 case (which the manifest can't
         express on older Windows SDKs).

      3. Declare supported Windows versions so feature-detection
         APIs return correct values on Windows 10 / 11.
  -->
  <assemblyIdentity
    type="win32"
    name="Amwall.Amwall"
    version="0.0.1.0"
    processorArchitecture="*" />

  <dependency>
    <dependentAssembly>
      <assemblyIdentity
        type="win32"
        name="Microsoft.Windows.Common-Controls"
        version="6.0.0.0"
        processorArchitecture="*"
        publicKeyToken="6595b64144ccf1df"
        language="*" />
    </dependentAssembly>
  </dependency>

  <application xmlns="urn:schemas-microsoft-com:asm.v3">
    <windowsSettings>
      <dpiAware xmlns="http://schemas.microsoft.com/SMI/2005/WindowsSettings">true/pm</dpiAware>
      <dpiAwareness xmlns="http://schemas.microsoft.com/SMI/2016/WindowsSettings">PerMonitorV2,PerMonitor</dpiAwareness>
    </windowsSettings>
  </application>

  <compatibility xmlns="urn:schemas-microsoft-com:compatibility.v1">
    <application>
      <!-- Windows 7 -->
      <supportedOS Id="{35138b9a-5d96-4fbd-8e2d-a2440225f93a}" />
      <!-- Windows 8 -->
      <supportedOS Id="{4a2f28e3-53b9-4441-ba9c-d69d4a4a6e38}" />
      <!-- Windows 8.1 -->
      <supportedOS Id="{1f676c76-80e1-4239-95bb-83d0f6d0da78}" />
      <!-- Windows 10 / 11 -->
      <supportedOS Id="{8e0f7a12-bfb3-4fe8-b9a5-48fd50a15a9a}" />
    </application>
  </compatibility>
</assembly>
