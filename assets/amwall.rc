                    LVS_REPORT | LVS_NOCOLUMNHEADER | LVS_SHAREIMAGELISTS | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP | WS_VSCROLL,
                    12, 16, 246, 144
    LTEXT           "Double-click an item to change it.", IDC_LBL_HIGHLIGHT_HINT, 12, 162, 246, 12, SS_CENTERIMAGE
END

// ---- Rules ----
IDD_SETTINGS_RULES DIALOGEX 0, 0, 270, 204
STYLE WS_CHILD | WS_SYSMENU | WS_TABSTOP | WS_GROUP | DS_SHELLFONT | DS_CONTROL
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    GROUPBOX        "Connections", IDC_GRP_CONNECTIONS, 4, 4, 262, 76, WS_GROUP
    AUTOCHECKBOX    "Block outbound connections for all", IDC_S_RULE_BLOCKOUTBOUND, 12, 16, 246, 12
    AUTOCHECKBOX    "Block inbound connections for all",  IDC_S_RULE_BLOCKINBOUND,  12, 30, 246, 12
    AUTOCHECKBOX    "Allow loopback connections for all", IDC_S_RULE_ALLOWLOOPBACK, 12, 44, 246, 12
    AUTOCHECKBOX    "Allow IPv6 redirections (6to4) for all", IDC_S_RULE_ALLOW6TO4,  12, 58, 246, 12

    GROUPBOX        "Security", IDC_GRP_SECURITY, 4, 86, 262, 46, WS_GROUP
    AUTOCHECKBOX    "Prevent port scanning (stealth mode)",       IDC_USESTEALTHMODE_CHK,        12, 98, 246, 12
    AUTOCHECKBOX    "Enable boot-time filters",                   IDC_INSTALLBOOTTIMEFILTERS_CHK,12, 112, 246, 12

    GROUPBOX        "Advanced", IDC_GRP_ADVANCED, 4, 138, 262, 60, WS_GROUP
    AUTOCHECKBOX    "Check apps for digital signatures",          IDC_USECERTIFICATES_CHK,       12, 150, 246, 12
    AUTOCHECKBOX    "Use file hashes for app identification",     IDC_USEHASHES_CHK,             12, 164, 246, 12
    AUTOCHECKBOX    "Resolve network addresses",                  IDC_USENETWORKRESOLUTION_CHK,  12, 178, 246, 12
END

