// ---- Exclude ----
IDD_SETTINGS_EXCLUDE DIALOGEX 0, 0, 270, 204
STYLE WS_CHILD | WS_SYSMENU | WS_TABSTOP | WS_GROUP | DS_SHELLFONT | DS_CONTROL
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI", 400, 0, 0x1
