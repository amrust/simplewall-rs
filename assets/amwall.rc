// amwall — Win32 resource script.
// Copyright (C) 2026  amwall contributors. Licensed GPL-3.0-or-later.
//
// Compiled by build.rs via the `embed-resource` crate. Holds:
//   - Application icon (shown by Explorer / taskbar / Alt-Tab).
//   - Application manifest (ComCtl32 v6 + DPI awareness — see
//     manifest.xml for the rationale).
//   - Modal dialog templates (rules editor + sub-dialogs). Each
//     template shape mirrors upstream simplewall's same-named
//     IDD_EDITOR* resources from src/resource.rc:250-366. Loaded
//     at runtime via DialogBoxParamW / CreateDialogParamW from
//     gui/rule_editor.rs.

#include <winres.h>

// ---------------------------------------------------------------
// Resource IDs.
//
// Numeric values match upstream's src/resource.h where possible,
// to keep both sources line-up against one another. Rust-side
// duplicates live in gui/ids.rs (control IDs) and gui/dlg_ids.rs
// (dialog-template IDs); manually hand-synced.
// ---------------------------------------------------------------

#define IDD_EDITOR              102
#define IDD_EDITOR_GENERAL      103
#define IDD_EDITOR_RULE         104
#define IDD_EDITOR_APPS         105
#define IDD_EDITOR_ADDRULE      106
#define IDD_APP_PROPERTIES      110

