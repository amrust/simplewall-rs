    AUTORADIOBUTTON "Block",   IDC_S_BLOCKLIST_UPDATE_BLOCK,   12, 104, 246, 12

    GROUPBOX        "Microsoft applications", IDC_GRP_BLOCKLIST_EXTRA, 4, 124, 262, 56, WS_GROUP
