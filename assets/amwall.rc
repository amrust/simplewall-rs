// ---------------------------------------------------------------
// Top-level resources.
// ---------------------------------------------------------------

// Main application icon (filters-active form, color).
1 ICON "icons/100.ico"

// Inactive variant (filters-disabled form, monochrome). The
// title-bar icon swaps between these two via WM_SETICON
// whenever Enable filters / Disable filters / Emergency reset
// changes filter state — same visual cue upstream simplewall
// uses to surface "is the firewall actually doing anything".
2 ICON "icons/101.ico"

// Application manifest.
1 24 "manifest.xml"

// Keyboard accelerator table — loaded by gui::run via
// LoadAcceleratorsW(IDR_MAIN_ACCEL) and translated in the
// message loop before WM_KEYDOWN / WM_CHAR dispatch.
//
// IDM_* values (255-303) are the same ones the menu/toolbar
// already handle in main_window::on_command, so the accelerator
// just becomes a synthetic WM_COMMAND with that ID.

#define IDR_MAIN_ACCEL 300

// IDM_REFRESH = 260, IDM_TRAY_START = 305, IDM_SETTINGS = 251,
// IDM_ADD_FILE = 252, IDM_IMPORT = 253, IDM_EXPORT = 254,
// IDM_OPENRULESEDITOR = 323, IDM_EXIT = 255.

IDR_MAIN_ACCEL ACCELERATORS
BEGIN
    VK_F5,  260, VIRTKEY                    // Refresh
    "T",    305, VIRTKEY, CONTROL           // Enable filters
    "P",    251, VIRTKEY, CONTROL           // Settings
    "O",    252, VIRTKEY, CONTROL           // Add app
    "I",    253, VIRTKEY, CONTROL           // Import profile
    "E",    254, VIRTKEY, CONTROL           // Export profile
    "R",    323, VIRTKEY, CONTROL           // Create rule
    "Q",    255, VIRTKEY, CONTROL           // Quit (Exit)
END

// ---------------------------------------------------------------
// Rule-editor dialog templates.
//
// Sizes / positions are in dialog units; Windows scales them to
// pixels via the chosen font (DS_SHELLFONT below picks Segoe UI
// on Windows 10/11). This is exactly the dance dialog templates
// were designed for — the editor doesn't need our own DPI math
// for the layout itself, just for any custom child controls
// (toolbars / etc.) added at runtime.
// ---------------------------------------------------------------

// Parent dialog: tab control + Enable rule + Save / Close.
IDD_EDITOR DIALOGEX 0, 0, 300, 230
STYLE WS_OVERLAPPEDWINDOW | WS_CLIPSIBLINGS | WS_CLIPCHILDREN | WS_POPUP | WS_VISIBLE | WS_BORDER | WS_SYSMENU | WS_CAPTION | WS_THICKFRAME | DS_SHELLFONT | DS_MODALFRAME
EXSTYLE WS_EX_APPWINDOW | WS_EX_CONTROLPARENT
CAPTION "Rule editor"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    CONTROL         "", IDC_TAB, "SysTabControl32", WS_CHILD | WS_VISIBLE | WS_CLIPSIBLINGS | WS_CLIPCHILDREN | WS_TABSTOP, 0, 0, 300, 200

    AUTOCHECKBOX    "Enable rule", IDC_ENABLE_CHK, 8, 207, 100, 14, BS_VCENTER | WS_TABSTOP

    DEFPUSHBUTTON   "Save",  IDC_SAVE,  188, 207, 50, 14, WS_TABSTOP
    PUSHBUTTON      "Close", IDC_CLOSE, 242, 207, 50, 14, WS_TABSTOP
END

// General tab page.
IDD_EDITOR_GENERAL DIALOGEX 0, 0, 300, 200
STYLE WS_CHILD | WS_SYSMENU | WS_TABSTOP | WS_GROUP | DS_SHELLFONT | DS_CONTROL
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    GROUPBOX        "Name:",     IDC_RULE_NAME,         6, 4, 286, 30, WS_GROUP
    EDITTEXT                     IDC_RULE_NAME_ID,     12, 16, 274, 14, WS_TABSTOP | ES_AUTOHSCROLL

    GROUPBOX        "Comments:", IDC_RULE_COMMENT,      6, 38, 286, 30, WS_GROUP
    EDITTEXT                     IDC_RULE_COMMENT_ID,  12, 50, 274, 14, WS_TABSTOP | ES_AUTOHSCROLL

    GROUPBOX        "Protocol:",            IDC_RULE_PROTOCOL,    6, 72, 140, 32, WS_GROUP
    COMBOBOX                                IDC_RULE_PROTOCOL_ID,12, 84, 128, 80, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP

    GROUPBOX        "Family (ports only):", IDC_RULE_VERSION,    152, 72, 140, 32, WS_GROUP
    COMBOBOX                                IDC_RULE_VERSION_ID, 158, 84, 128, 80, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP

    GROUPBOX        "Direction:", IDC_RULE_DIRECTION,    6, 108, 286, 32, WS_GROUP
    COMBOBOX                      IDC_RULE_DIRECTION_ID,12, 120, 274, 80, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP

    GROUPBOX        "Action:",    IDC_RULE_ACTION,       6, 144, 286, 32, WS_GROUP
    COMBOBOX                      IDC_RULE_ACTION_ID,   12, 156, 274, 80, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP
END

// Rule tab page (remote + local rule fragments).
IDD_EDITOR_RULE DIALOGEX 0, 0, 300, 200
STYLE WS_CHILD | WS_SYSMENU | WS_TABSTOP | WS_GROUP | DS_SHELLFONT | DS_CONTROL
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    GROUPBOX        "Remote:", IDC_RULE_REMOTE, 6, 4, 286, 70, WS_GROUP
    CONTROL         "", IDC_RULE_REMOTE_ID, "SysListView32",
                    LVS_REPORT | LVS_NOCOLUMNHEADER | LVS_SHAREIMAGELISTS | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP | WS_VSCROLL,
                    14, 16, 220, 50

    PUSHBUTTON      "Add",    IDC_RULE_REMOTE_ADD,    240, 16, 46, 14, WS_TABSTOP
    PUSHBUTTON      "Edit",   IDC_RULE_REMOTE_EDIT,   240, 34, 46, 14, WS_TABSTOP
    PUSHBUTTON      "Delete", IDC_RULE_REMOTE_DELETE, 240, 52, 46, 14, WS_TABSTOP

    GROUPBOX        "Local:", IDC_RULE_LOCAL, 6, 78, 286, 70, WS_GROUP
    CONTROL         "", IDC_RULE_LOCAL_ID, "SysListView32",
                    LVS_REPORT | LVS_NOCOLUMNHEADER | LVS_SHAREIMAGELISTS | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP | WS_VSCROLL,
                    14, 90, 220, 50

    PUSHBUTTON      "Add",    IDC_RULE_LOCAL_ADD,    240, 90, 46, 14, WS_TABSTOP
    PUSHBUTTON      "Edit",   IDC_RULE_LOCAL_EDIT,   240, 108, 46, 14, WS_TABSTOP
    PUSHBUTTON      "Delete", IDC_RULE_LOCAL_DELETE, 240, 126, 46, 14, WS_TABSTOP

    LTEXT           "If you leave the lists blank, the rule applies to any address and port.",
                    IDC_RULE_HINT, 6, 154, 286, 22
END

// Apps tab page (search + checkbox listview).
IDD_EDITOR_APPS DIALOGEX 0, 0, 300, 200
STYLE WS_CHILD | WS_SYSMENU | WS_TABSTOP | WS_GROUP | DS_SHELLFONT | DS_CONTROL
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    EDITTEXT        IDC_SEARCH, 4, 4, 292, 14, WS_TABSTOP | ES_AUTOHSCROLL
    CONTROL         "", IDC_RULE_APPS_ID, "SysListView32",
                    LVS_REPORT | LVS_SHAREIMAGELISTS | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP | WS_VSCROLL,
                    4, 22, 292, 154

    LTEXT           "If no apps are selected, the rule applies to all apps.",
                    IDC_RULE_APPS_HINT, 6, 180, 286, 14
END

