// ---- Settings parent dialog ----
//
// REMOVED — Settings is now built on the Win32 PropertySheet API
// (settings_dialog.rs), which creates the parent dialog, tab strip,
// and OK/Cancel buttons internally. The page templates below
// (IDD_SETTINGS_GENERAL etc.) are still used as PropertySheet pages.

// ---- General ----
IDD_SETTINGS_GENERAL DIALOGEX 0, 0, 270, 204
STYLE WS_CHILD | WS_SYSMENU | WS_TABSTOP | WS_GROUP | DS_SHELLFONT | DS_CONTROL
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    GROUPBOX        "General configuration", IDC_GRP_GENERAL_CONFIG, 4, 4, 262, 90, WS_GROUP
    AUTOCHECKBOX    "Always on top",                    IDC_ALWAYSONTOP_CHK,    12, 16, 246, 12
    AUTOCHECKBOX    "Load on system startup",           IDC_LOADONSTARTUP_CHK,  12, 30, 246, 12
    AUTOCHECKBOX    "Start minimized",                  IDC_STARTMINIMIZED_CHK, 12, 44, 246, 12
    AUTOCHECKBOX    "Skip ""User Account Control"" prompt warning", IDC_SKIPUACWARNING_CHK, 12, 58, 246, 12
    AUTOCHECKBOX    "Periodically check for updates (recommended)", IDC_CHECKUPDATES_CHK, 12, 72, 246, 12

    GROUPBOX        "Language",   IDC_GRP_LANGUAGE, 4, 100, 262, 38, WS_GROUP
    LTEXT           "Select language:", IDC_LBL_SELECT_LANGUAGE, 12, 116, 100, 12, SS_CENTERIMAGE
    COMBOBOX        IDC_LANGUAGE, 116, 114, 142, 80, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP
END

// ---- Interface (confirmations + tray) ----
IDD_SETTINGS_INTERFACE DIALOGEX 0, 0, 270, 204
STYLE WS_CHILD | WS_SYSMENU | WS_TABSTOP | WS_GROUP | DS_SHELLFONT | DS_CONTROL
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    GROUPBOX        "Confirmations", IDC_GRP_CONFIRMATIONS, 4, 4, 262, 76, WS_GROUP
    AUTOCHECKBOX    "Show confirmation dialog on exit",                     IDC_CONFIRMEXIT_CHK,      12, 16, 246, 12
    AUTOCHECKBOX    "Show confirmation dialog on exit when timers active",  IDC_CONFIRMEXITTIMER_CHK, 12, 30, 246, 12
    AUTOCHECKBOX    "Confirm when clearing the log file",                   IDC_CONFIRMLOGCLEAR_CHK,  12, 44, 246, 12
    AUTOCHECKBOX    "Confirm allowing previously-blocked traffic",          IDC_CONFIRMALLOW_CHK,     12, 58, 246, 12

    GROUPBOX        "Tray icon", IDC_GRP_TRAYICON, 4, 86, 262, 32, WS_GROUP
    AUTOCHECKBOX    "Single click on tray icon to open", IDC_TRAYICONSINGLECLICK_CHK, 12, 100, 246, 12
END

