    AUTOCHECKBOX    "user rules",  IDC_EXCLUDECUSTOM_CHK,    12, 30, 246, 12

    GROUPBOX        "Logging: do not log ...", IDC_GRP_EXCLUDE_LOG, 4, 56, 262, 46, WS_GROUP
    AUTOCHECKBOX    "port scanner connections", IDC_EXCLUDESTEALTH_CHK,        12, 68, 246, 12
    AUTOCHECKBOX    "allowed connections",      IDC_EXCLUDECLASSIFYALLOW_CHK,  12, 82, 246, 12
END

// Add/edit-one-rule-fragment sub-dialog.
IDD_EDITOR_ADDRULE DIALOGEX 0, 0, 280, 156
STYLE WS_CLIPSIBLINGS | WS_CLIPCHILDREN | WS_POPUP | WS_VISIBLE | WS_BORDER | WS_SYSMENU | WS_CAPTION | DS_SHELLFONT | DS_MODALFRAME
CAPTION "Rule entry"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    EDITTEXT        IDC_RULE_ID,      8, 8, 264, 14, WS_TABSTOP | ES_AUTOHSCROLL

    EDITTEXT        IDC_RULE_ID_HINT, 8, 28, 264, 96,
                    WS_VSCROLL | NOT WS_TABSTOP | ES_AUTOVSCROLL | ES_READONLY | ES_MULTILINE

    DEFPUSHBUTTON   "Save",  IDC_SAVE,  166, 132, 50, 14, WS_TABSTOP
    PUSHBUTTON      "Close", IDC_CLOSE, 220, 132, 50, 14, WS_TABSTOP
END

// ---------------------------------------------------------------
// App properties dialog (M5.4c follow-up — modeled on the Settings
// page templates: fixed-size, dialog-template-driven, modal).
// Shown when the user picks Properties on a row in any of the
// Apps / Services / UWP tabs.
// ---------------------------------------------------------------
IDD_APP_PROPERTIES DIALOGEX 0, 0, 270, 130
STYLE WS_CLIPSIBLINGS | WS_CLIPCHILDREN | WS_POPUP | WS_VISIBLE | WS_BORDER | WS_SYSMENU | WS_CAPTION | DS_SHELLFONT | DS_MODALFRAME
EXSTYLE WS_EX_APPWINDOW | WS_EX_CONTROLPARENT
CAPTION "App properties"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    GROUPBOX        "Path:", IDC_GRP_APPPROP_PATH, 4, 4, 262, 32, WS_GROUP
    EDITTEXT        IDC_APPPROP_PATH_ID, 10, 16, 250, 14,
                    WS_TABSTOP | ES_AUTOHSCROLL | ES_READONLY

    GROUPBOX        "Comment:", IDC_GRP_APPPROP_COMMENT, 4, 40, 262, 32, WS_GROUP
    EDITTEXT        IDC_APPPROP_COMMENT_ID, 10, 52, 250, 14,
                    WS_TABSTOP | ES_AUTOHSCROLL

    GROUPBOX        "Settings:", IDC_GRP_APPPROP_SETTINGS, 4, 76, 262, 30, WS_GROUP
    AUTOCHECKBOX    "Enabled (allow this app's traffic)",
                    IDC_APPPROP_ENABLED_CHK, 12, 88, 150, 12, WS_TABSTOP
    AUTOCHECKBOX    "Silent (no notifications)",
                    IDC_APPPROP_SILENT_CHK,  166, 88, 96,  12, WS_TABSTOP

    DEFPUSHBUTTON   "Save",  IDC_SAVE,  158, 110, 50, 14, WS_TABSTOP
    PUSHBUTTON      "Close", IDC_CLOSE, 212, 110, 50, 14, WS_TABSTOP
END

// ---------------------------------------------------------------
// Connect prompt — centered Allow/Block dialog popped when an
// app's first connection hits amwall's default-deny while
// notifications are on. DS_CENTER auto-centers on screen.
// ---------------------------------------------------------------
IDD_CONNECT_PROMPT DIALOGEX 0, 0, 340, 160
STYLE WS_CLIPSIBLINGS | WS_CLIPCHILDREN | WS_POPUP | WS_BORDER | WS_SYSMENU | WS_CAPTION | DS_SHELLFONT | DS_MODALFRAME | DS_CENTER
EXSTYLE WS_EX_APPWINDOW | WS_EX_CONTROLPARENT | WS_EX_NOACTIVATE
CAPTION "amwall - application connection request"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "An application is trying to connect:", IDC_PROMPT_HEADER, 12, 10, 316, 12
    LTEXT           "(path)",   IDC_PROMPT_PATH,   12, 26, 316, 46
    LTEXT           "(remote)", IDC_PROMPT_REMOTE, 12, 76, 316, 14

    LTEXT           "Allow this app's traffic, or keep it blocked?", IDC_PROMPT_QUESTION, 12, 96, 316, 12

    LTEXT           "", IDC_PROMPT_COUNTDOWN, 12, 130, 150, 12

    PUSHBUTTON      "Allow", IDC_PROMPT_ALLOW, 174, 124, 70, 22,
                    WS_TABSTOP | BS_OWNERDRAW
    PUSHBUTTON      "Block", IDC_PROMPT_BLOCK, 252, 124, 70, 22,
                    WS_TABSTOP | BS_OWNERDRAW
END
