<?xml version="1.0" encoding="utf-8"?>
<!--
  amwall WiX installer template.
  Copyright (C) 2026  amwall contributors. Licensed GPL-3.0-or-later.

  Built into a standalone MSI by `cargo wix`. See
  .github/workflows/release.yml and .vscode/tasks.json for the
  exact invocation (release-target build, then cargo wix with
  no-build / nocapture / x86_64-pc-windows-msvc).

  cargo-wix injects $(var.Version) from Cargo.toml's version
  field and $(var.CargoTargetBinDir) which resolves to
  `target\x86_64-pc-windows-msvc\release` for the build above.

  GUIDs:
    * UpgradeCode is stable across versions; never regenerate it.
      That stable id is how the MSI recognises "this is an upgrade
      of amwall, remove the old one first" instead of "this is a
      different product".
    * Component GUIDs (MainExecutable / LicenseFile / Shortcut)
      must stay stable per file or folder identity. Changing one
      would tell the installer to keep both old and new on
      uninstall.

  XML comments cannot contain a double-dash (it's the end-of-comment
  marker), so flag-style examples in this header use prose rather
  than literal `option-name` syntax.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="amwall"
    UpgradeCode="A8F3E2C1-9B4D-4C7E-8F1A-3D2C5B6E7F81"
    Language="1033"
    Codepage="65001"
    Version="$(var.Version)"
    Manufacturer="amwall contributors">

    <Package
      Id="*"
      Keywords="Installer,Firewall,WFP,simplewall"
      Description="amwall - Rust port of simplewall (Windows Filtering Platform firewall)"
      Manufacturer="amwall contributors"
      InstallerVersion="450"
      Languages="1033"
      Compressed="yes"
      InstallScope="perMachine"
      SummaryCodepage="1252" />

    <MajorUpgrade
      Schedule="afterInstallInitialize"
      DowngradeErrorMessage="A newer version of amwall is already installed. Uninstall it first if you want to downgrade." />

    <Media Id="1" Cabinet="amwall.cab" EmbedCab="yes" />

    <!-- Filesystem layout: C:\Program Files\amwall\amwall.exe + LICENSE -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="APPLICATIONFOLDER" Name="amwall">
          <Component Id="MainExecutable" Guid="3E8D4F29-7C5A-4B1E-9D2F-6A4B8C1E5D3A" Win64="yes">
            <File Id="amwallEXE"
                  Name="amwall.exe"
                  Source="$(var.CargoTargetBinDir)\amwall.exe"
                  KeyPath="yes" />
          </Component>
          <Component Id="LicenseFile" Guid="5D7E3F1A-8B2C-4D9E-A1F5-7B3C9E2D6A4F" Win64="yes">
            <File Id="LICENSE"
                  Name="LICENSE"
                  Source="LICENSE"
                  KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>

      <!-- Start Menu: Programs\amwall\amwall -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="amwall">
          <Component Id="ApplicationShortcut" Guid="F2A1B9C4-3D5E-4F8A-B7C1-2E9D4A6F3B8C">
            <Shortcut Id="ApplicationStartMenuShortcut"
                      Name="amwall"
                      Description="Rust port of simplewall (Windows Filtering Platform firewall)"
                      Target="[#amwallEXE]"
                      WorkingDirectory="APPLICATIONFOLDER" />
            <!-- RemoveFolder on uninstall: clean up the empty
                 Programs\amwall directory once the shortcut is gone. -->
            <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
            <!-- KeyPath has to be a registry value (not a file)
                 for advertised shortcuts; HKCU\Software\amwall\installed
                 doubles as a "did the per-user install complete"
                 sentinel that Windows uses for shortcut repair. -->
            <RegistryValue Root="HKCU"
                           Key="Software\amwall"
                           Name="installed"
                           Type="integer"
                           Value="1"
                           KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id="MainProgram" Title="amwall" Level="1"
             Description="Install amwall.exe and create Start Menu shortcut"
             ConfigurableDirectory="APPLICATIONFOLDER">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="LicenseFile" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <!-- WixUI_InstallDir flow extended with a custom changelog page:
         Welcome -> License -> Changelog -> InstallDir -> Verify
         -> Progress -> Finish. WixUILicenseRtf points at
         wix/License.rtf (GPL-3.0). The Changelog page reads
         wix/Changelog.rtf with the latest version pinned at the
         top, so users can see what's new before they confirm
         the install path. -->
    <UI>
      <UIRef Id="WixUI_InstallDir" />

      <Dialog Id="ChangelogDlg" Width="370" Height="270"
              Title="!(loc.ChangelogDlgTitle)"
              NoMinimize="yes">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15"
                 Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}!(loc.ChangelogTitle)" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15"
                 Transparent="yes" NoPrefix="yes"
                 Text="!(loc.ChangelogDesc)" />
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44"
                 TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="ChangelogText" Type="ScrollableText"
                 X="20" Y="55" Width="330" Height="170"
                 Sunken="yes" TabSkip="no">
          <Text SourceFile="wix\Changelog.rtf" />
        </Control>

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17"
                 Text="!(loc.WixUIBack)">
          <Publish Event="NewDialog" Value="LicenseAgreementDlg">1</Publish>
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17"
                 Default="yes" Text="!(loc.WixUINext)">
          <Publish Event="NewDialog" Value="InstallDirDlg">1</Publish>
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17"
                 Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- Splice ChangelogDlg between LicenseAgreementDlg and
           InstallDirDlg. The default WixUI_InstallDir routing
           wires License -> InstallDir directly; Order="3" pushes
           our routing ahead of the built-in Order="1"/"2". -->
      <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="NewDialog"
               Value="ChangelogDlg" Order="3">LicenseAccepted = "1"</Publish>
      <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog"
               Value="ChangelogDlg" Order="3">1</Publish>
    </UI>
    <Property Id="WIXUI_INSTALLDIR" Value="APPLICATIONFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="wix\License.rtf" />

    <!-- Add/Remove Programs metadata. Without explicit values,
         WiX synthesises some from <Package> attributes; setting
         them explicitly makes the entry behave nicely under
         winget search amwall etc. -->
    <Property Id="ARPCONTACT" Value="https://github.com/amrust/amwall" />
    <Property Id="ARPHELPLINK" Value="https://github.com/amrust/amwall/issues" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/amrust/amwall" />

    <!-- Install-time language marker. The MSI runs as Administrator
         (perMachine), but `Impersonate="yes"` on the deferred CA makes
         it run as the original installing user so %APPDATA% resolves
         correctly. The script writes the auto-applied transform's
         LCID (passed in via CustomActionData, set by the immediate CA
         that runs immediately before) to
         %APPDATA%\amwall\installerlocale.txt. amwall reads that file
         on every startup; when its content differs from the LCID
         already recorded in settings.txt (install_lcid_seen), the
         saved `language` is overwritten with the install language so
         users land in whatever locale they installed in — including
         users upgrading from a pre-multilingual MSI whose old
         settings.txt has a stale `language=en`.

         CA returns are ignored — a failed write must never block
         install; amwall simply falls back to system-locale auto-detect. -->
    <Binary Id="WriteInstallerLocaleScript"
            SourceFile="wix\scripts\write-installer-locale.vbs" />

    <CustomAction Id="SetWriteInstallerLocaleData"
                  Property="WriteInstallerLocale"
                  Value="[ProductLanguage]" />

    <CustomAction Id="WriteInstallerLocale"
                  BinaryKey="WriteInstallerLocaleScript"
                  VBScriptCall="WriteInstallerLocale"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="SetWriteInstallerLocaleData" Before="WriteInstallerLocale">NOT REMOVE</Custom>
      <Custom Action="WriteInstallerLocale" After="InstallFiles">NOT REMOVE</Custom>
    </InstallExecuteSequence>
  </Product>
</Wix>
