# Force LF line endings on anything that runs on Linux. Windows
# editing must not introduce CRLF — dpkg refuses to execute a
# maintainer script with CRLF (the shebang line gets read as
# "#!/bin/sh\r" and exec hunts for a file literally named "sh\r").
#
# Cargo + CMake + .toml + Markdown also prefer LF for cross-platform
# stability; only legacy Windows tooling needs CRLF and there's none
# in this tree.

*.sh             text eol=lf
*.rs             text eol=lf
*.cpp            text eol=lf
*.h              text eol=lf
*.toml           text eol=lf
*.md             text eol=lf
*.txt            text eol=lf
CMakeLists.txt   text eol=lf
*.service        text eol=lf
*.desktop        text eol=lf
*.conf           text eol=lf
*.policy         text eol=lf
.gitignore       text eol=lf
.gitattributes   text eol=lf

# Debian maintainer scripts — no extension, but they're /bin/sh
# scripts. Same LF requirement as *.sh.
linux/amwall-daemon/debian/postinst  text eol=lf
linux/amwall-daemon/debian/prerm     text eol=lf
linux/amwall-daemon/debian/postrm    text eol=lf

# Phase 6.10 — vendored crate sources. cargo's offline mode verifies
# every vendored file byte-for-byte against .cargo-checksum.json, so
# autocrlf-on-checkout would corrupt the checksums on a Windows
# reclone (and silently break `--frozen --offline`). `-text` forces
# git to treat the entire vendor tree as binary: no eol conversion,
# byte-perfect on every platform.
# (Only linux/vendor exists — the ebpf workspace's vendor was
# removed because cargo vendor can't see build-std sysroot deps.)
linux/vendor/**             -text
